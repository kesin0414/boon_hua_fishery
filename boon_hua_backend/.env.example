# Copy to .env for local development (do not commit real keys).

# --- AI recipes (Render) ---
# auto = ChatGPT first, Gemini fallback (default)
# AI_PROVIDER=auto
OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_google_ai_studio_key
# GEMINI_MODEL=gemini-2.0-flash-lite

# --- Firebase (Render: FIREBASE_CREDENTIALS_JSON) ---
# Download from Firebase Console → Project boon-hua-fishery → Service accounts → Generate new private key
# Option A: save file as boon_hua_backend/firebase_credentials.json (gitignored)
# Option B: paste full JSON on one line:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"boon-hua-fishery",...}

# --- Production API URL (admin Settings → Mobile Recipe API) ---
# https://boon-hua-fishery.onrender.com
